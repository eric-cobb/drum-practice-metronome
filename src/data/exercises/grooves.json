      "number": 4,
      "name": "Flams, drags & ghosts",
      "sectionId": "ornaments",
      "timeSignature": { "numerator": 4, "denominator": 4 },
      "subdivision": "16th",
      "notes": "An ornament on each quarter (flam, drag, ruff, buzz) with ghost notes on the in-betweens.",
      "pattern": [
