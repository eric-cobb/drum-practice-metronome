  "exercises": [
    {
      "id": "snare-kick",
      "number": 1,
      "name": "Snare & kick",
      "sectionId": "coordination",
      "timeSignature": { "numerator": 4, "denominator": 4 },
      "subdivision": "8th",
      "notes": "Snare on the upbeats (stems up), kick on the offbeats (stems down). Demonstrates a two-voice staff.",
      "pattern": [
        [
          { "voices": ["snare"], "sticking": "R" },
          { "voices": ["kick"] },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["kick"] },
          { "voices": ["snare"], "sticking": "R" },
          { "voices": ["kick"] },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["kick"] }
        ]
      ]
    },
    {
      "id": "eighth-rock",
      "number": 2,
      "name": "Eighth-note rock",
      "sectionId": "grooves",
      "timeSignature": { "numerator": 4, "denominator": 4 },
      "subdivision": "8th",
      "notes": "Hi-hat on every eighth, kick on 1 and 3, accented snare backbeat on 2 and 4. Grooves omit sticking — the limbs are fixed.",
      "pattern": [
        [
          { "voices": ["hihat-closed", "kick"] },
          { "voices": ["hihat-closed"] },
          { "voices": ["hihat-closed", "snare"], "accent": true },
          { "voices": ["hihat-closed"] },
          { "voices": ["hihat-closed", "kick"] },
          { "voices": ["hihat-closed"] },
          { "voices": ["hihat-closed", "snare"], "accent": true },
          { "voices": ["hihat-closed"] }
        ]
      ]
    },
    {
      "id": "accented-singles",
      "number": 3,
      "name": "Accented singles",
      "sectionId": "dynamics",
      "timeSignature": { "numerator": 4, "denominator": 4 },
      "subdivision": "16th",
      "notes": "Single strokes with an accent on each quarter — the accented notes also click louder.",
      "pattern": [
        [
          { "voices": ["snare"], "sticking": "R", "accent": true },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R" },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R", "accent": true },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R" },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R", "accent": true },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R" },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R", "accent": true },
          { "voices": ["snare"], "sticking": "L" },
          { "voices": ["snare"], "sticking": "R" },
          { "voices": ["snare"], "sticking": "L" }
        ]
      ]
    },
    {
